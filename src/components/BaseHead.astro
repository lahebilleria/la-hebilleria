---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "La Hebillería - Proveedor Mayorista de Accesorios para el Cabello",
  description = "Proveedor mayorista de accesorios para el pelo. Colitas, vinchas, hebillas, broches al por mayor. Compra mínima $20.000. Envíos a todo el país."
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteURL = Astro.site?.toString() || 'https://lahebilleria.com.ar';
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<!-- Title & Description -->
<title>{title}</title>
<meta name="description" content={description} />

<!-- SEO Keywords -->
<meta name="keywords" content="accesorios cabello mayorista, accesorios pelo por mayor, colitas mayorista, vinchas por mayor, hebillas mayorista, argentina" />
<meta name="author" content="La Hebillería" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL('/og-image.jpg', siteURL)} />
<meta property="og:locale" content="es_AR" />

<!-- Tipografía principal -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Bangers&display=swap" rel="stylesheet" />

<!-- Favicons -->
<link rel="icon" href="/favicon.ico" sizes="32x32" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />

<!-- SEO Robots -->
<meta name="robots" content="index, follow" />

<!-- Theme Color -->
<meta name="theme-color" content="#ff9900" />

<!-- Preconnect para performance -->
<link rel="preconnect" href="https://res.cloudinary.com" />