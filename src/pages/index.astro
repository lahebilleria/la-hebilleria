---
import BaseLayout from "../layouts/BaseLayout.astro";
import BaseHead from "../components/BaseHead.astro";
import Hero from "../components/landing/Hero.astro";
import WholesaleBadge from '../components/landing/Wholesalebadge';
---

<BaseLayout>
  <BaseHead
    title="Bijouterie por Mayor para Comercios | La Hebilleria"
    description="Venta mayorista de bijouterie y artículos de temporada. Proveedor para kioscos y comercios. Compra mínima, combos y atención por WhatsApp."
    canonical="https://www.lahebilleria.com.ar/"
  />
  <WholesaleBadge />
  <Hero/>
    <section> 
      <h2>Venta mayorista de bijouterie para comercios</h2>
      <p class="text-base text-gray-600 leading-relaxed">
        La Hebillería es un proveedor mayorista de bijouterie y accesorios para
        comercios, locales y revendedores. Ofrecemos colitas, vinchas, hebillas,
        broches y artículos infantiles con alta rotación, compra mínima accesible
        y atención personalizada por WhatsApp.
      </p>
  </section>
</BaseLayout>