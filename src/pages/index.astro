---
import BaseLayout from "../layouts/BaseLayout.astro";
import BaseHead from "../components/BaseHead.astro";
import Hero from "../components/landing/Hero.astro";
import WholesaleBadge from '../components/landing/Wholesalebadge';
---

<BaseLayout>
  <BaseHead
    title="Accesorios para el Cabello por Mayor | La Hebillería"
    description="Venta mayorista de accesorios para el pelo y artículos de temporada. Proveedor para kioscos y comercios. Compra mínima, combos y atención por WhatsApp."
  />
  <WholesaleBadge />
  <Hero/>
    <section> 
      <h2>Venta mayorista de accesorios para el cabello para comercios</h2>
      <p class="text-base text-gray-600 leading-relaxed">
        La Hebillería es un proveedor mayorista de accesorios para el pelo y 
        adornos para comercios, locales y revendedores. Ofrecemos colitas, vinchas, 
        hebillas, broches y artículos infantiles con alta rotación, compra mínima 
        accesible y atención personalizada por WhatsApp.
      </p>
  </section>
</BaseLayout>